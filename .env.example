# Copier vers .env et remplir (ne pas committer .env)

# Admin
REACT_APP_ADMIN_PASSWORD=

# Firebase (optionnel — sinon localStorage)
REACT_APP_FIREBASE_API_KEY=
REACT_APP_FIREBASE_AUTH_DOMAIN=
REACT_APP_FIREBASE_PROJECT_ID=

# EmailJS — invitation + rappel (obligatoire pour les mails invités)
REACT_APP_EMAILJS_PUBLIC_KEY=
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_INVITATION=
REACT_APP_EMAILJS_TEMPLATE_RAPPEL=

# EmailJS — notification à chaque RSVP (ex. ta sœur)
# Créer un 3e template ; champ To : {{to_email}}
REACT_APP_EMAILJS_TEMPLATE_NOTIFY_ORGANIZER=
REACT_APP_NOTIFY_ORGANIZER_EMAIL=
